{
  "name": "file-processing-pipeline",
  "version": "0.0.1",
  "private": true,
  "description": "File processing pipeline — modular monolith monorepo",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "start:dev": "pnpm --filter @repo/api run start:dev",
    "start:stage": "pnpm --filter @repo/api run start:stage",
    "start:prod": "pnpm --filter @repo/api run start:prod",
    "test": "turbo run test",
    "migrate:generate": "pnpm --filter @repo/api run migrate:generate",
    "migrate:up": "pnpm --filter @repo/api run migrate:up",
    "migrate:down": "pnpm --filter @repo/api run migrate:down",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^2.8.8",
    "sonarqube-scanner": "^3.5.0",
    "turbo": "^2.5.4",
    "typescript": "^5.1.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
