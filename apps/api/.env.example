# =============================================================================
# @repo/api — Backend environment template
# =============================================================================
#
# Location: apps/api/ (this package only)
#
# Setup:
#   cp .env.example .env.development
#   # optional:
#   cp .env.example .env.staging
#   cp .env.example .env.production
#
# Nest loads:  .env.{NODE_ENV}  from apps/api (bootstrap config.module)
# Migrations:  NODE_ENV=development pnpm run migrate:up  (from repo root or apps/api)
#
# Never commit real secrets. Only .env.example is tracked in git.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# development | staging | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# Application (bootstrap)
# Railway may inject PORT — map to APP_PORT in Railway variables if needed.
# -----------------------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
APP_DEBUG=true
# URI versioning: /api/v1/...
APP_VERSIONING=true

# -----------------------------------------------------------------------------
# PostgreSQL — Neon (primary database)
# Used by: shared/infrastructure/database (TypeORM + migrations)
# -----------------------------------------------------------------------------
DB_HOST=ep-xxxx.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_USERNAME=your_neon_user
DB_PASSWORD=your_neon_password
DB_NAME=file_processing_pipeline
# true = TypeORM auto-sync schema (local dev only). false = use migrations.
DB_SYNCHRONIZE=false
# Neon / managed Postgres: true. Local Docker: false
DB_SSL=true

# -----------------------------------------------------------------------------
# Redis — Upstash or self-hosted
# Used by: cache module, TypeORM query cache, Bull queues (when wired)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
# Upstash: host + password from dashboard; REDIS_USERNAME=default; REDIS_TLS=true
# Self-hosted: localhost, no TLS, password only if you set one
REDIS_TLS=false

# -----------------------------------------------------------------------------
# Identity — OAuth (modules/identity/integrations/oauth)
# Self-built session/JWT complements OAuth sign-in.
# -----------------------------------------------------------------------------
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
# Must match provider console redirect URI
OAUTH_CALLBACK_URL=http://localhost:3000/api/v1/auth/oauth/callback

JWT_ACCESS_SECRET=replace-with-long-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-string-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# -----------------------------------------------------------------------------
# Object storage — Cloudflare R2 (modules/storage)
# S3-compatible API
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=file-processing-uploads
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Billing — Razorpay & Stripe (modules/billing)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Background jobs — Bull on Redis (src/jobs, shared/infrastructure/messaging)
# -----------------------------------------------------------------------------
BULL_PREFIX=file-pipeline
QUEUE_DEFAULT_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Notifications (modules/notifications)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Observability (Winston uses APP_DEBUG today; ELK later)
# -----------------------------------------------------------------------------
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# CORS — allowed origin for @repo/web
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3001

# -----------------------------------------------------------------------------
# External HTTP (shared/infrastructure/service-gateway)
# -----------------------------------------------------------------------------
OTHER_SERVICE_URL=http://localhost:4000
